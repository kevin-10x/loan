# Copy this file to .env and fill in your OWN Safaricom Daraja sandbox credentials.
# Get these from https://developer.safaricom.co.ke after creating an app.
# NEVER commit your real .env file or credentials to source control.

PORT=4000

# Daraja app credentials (sandbox)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_ENV=sandbox                     # sandbox | production

# B2C (used to DISBURSE approved loans to the borrower's own M-Pesa number)
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=your_encrypted_security_credential
MPESA_B2C_SHORTCODE=600000             # Your sandbox B2C shortcode from the Daraja portal
MPESA_B2C_COMMAND_ID=BusinessPayment   # SalaryPayment | BusinessPayment | PromotionPayment

# C2B / STK Push (used LATER, for the borrower to make a REPAYMENT on schedule -
# never used to charge a fee before the loan is disbursed)
MPESA_PAYBILL_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey

# Public callback URLs - use ngrok in local dev, e.g. https://abcd1234.ngrok-free.app
BASE_URL=https://your-public-url.example.com
